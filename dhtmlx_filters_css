.date-filter-popup {
	display: none;
	position: absolute;
	z-index: 100;
	background: #368ac0;
	border: 1px solid #ccc;
	padding: 10px;
}


.date-filter-icon,
.reset-filter-icon {
	cursor: pointer;
	display: flex;
	flex-direction: column;
	line-height: 20px;
	font-size : 10px;
	font-family:helvetica, arial, verdana, sans-serif;
}

[data-date-filter] {
	display: flex;
	flex-direction: column;
	line-height: 20px;
}

.filter-icon-container {
	display: flex;
	align-items: center;
	justify-content: center;
	color : #fff;
	gap: 3px;
	padding: 0 10px;
}

.filter-icon-container>button {
	border: none;
	background: transparent;
	cursor: pointer;
}

.filter-icon-container>button:hover {
	text-decoration: underline;
}

.date-filter-value {
	flex-grow: 1;
	font-size : 10px;
	color : #fff;
	font-family:helvetica, arial, verdana, sans-serif;
}

.reset-filter-icon {
	font-size : 10px;
	font-family:helvetica, arial, verdana, sans-serif;
	color : #fff;
}
.date-filter-apply {
	font-size : 10px;
	font-family:helvetica, arial, verdana, sans-serif;
}

.date-filter-input{
	font-size : 10px;
	font-family:helvetica, arial, verdana, sans-serif;
}
.date-filter-selet{
	font-size : 10px;
	font-family:helvetica, arial, verdana, sans-serif;
}

.gantt_grid_scale .gantt_grid_head_cell {
	display: inline-flex;
	flex-direction: column;
	padding: 5px 7px;
	line-height: 30px;
}

input {
	border-radius: 8px;
	padding-left: 5px;
}
